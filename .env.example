# =============================================================================
# SIMPLY LAWVERSE - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control
# =============================================================================

# =============================================================================
# FLASK CONFIGURATION
# =============================================================================
# Environment: development, production, or testing
FLASK_ENV=development
FLASK_APP=app.py
FLASK_DEBUG=1  # Set to 0 in production

# Secret key for session encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# For Development (SQLite - simple, no setup required):
DATABASE_URL=sqlite:///site.db

# For Production (PostgreSQL - recommended):
# DATABASE_URL=postgresql://username:password@localhost:5432/simplylawverse_db
# Install: pip install psycopg2-binary

# For Production (MySQL):
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/simplylawverse_db
# Install: pip install pymysql

# Database pool settings (for production)
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_POOL_PRE_PING=true
SQLALCHEMY_ECHO=false  # Set to true to debug SQL queries

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# SMTP Server (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password  # Use app-specific password for Gmail
MAIL_DEFAULT_SENDER=noreply@simplylawverse.com

# For SendGrid:
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key

# For AWS SES:
# MAIL_SERVER=email-smtp.region.amazonaws.com
# MAIL_PORT=587
# MAIL_USERNAME=your-ses-username
# MAIL_PASSWORD=your-ses-password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# HTTPS enforcement (set to true in production)
PREFERRED_URL_SCHEME=https

# Cookie security settings
SESSION_COOKIE_SECURE=false  # Set to true if using HTTPS in production
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600  # Session timeout in seconds (1 hour)

# CORS settings
CORS_ORIGINS=http://localhost:5000  # Comma-separated list of allowed origins

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
MAX_CONTENT_LENGTH=16777216  # 16 MB in bytes
UPLOAD_FOLDER=static/uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx

# =============================================================================
# RATE LIMITING
# =============================================================================
RATELIMIT_STORAGE_URL=memory://  # Use Redis for production: redis://localhost:6379

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text
LOG_FILE=logs/simplylawverse.log
LOG_MAX_BYTES=10485760  # 10 MB
LOG_BACKUP_COUNT=10

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# API Keys and external services
ADMIN_EMAIL=admin@simplylawverse.com

# Application name and version
APP_NAME=Simply Lawverse
APP_VERSION=1.0.0

# =============================================================================
# OPTIONAL: DEVELOPMENT-ONLY SETTINGS
# =============================================================================
# Debug toolbar (development only)
DEBUG_TB_ENABLED=false

# Testing configuration
TESTING=false

# =============================================================================
# OPTIONAL: AWS/CLOUD STORAGE (for production file uploads)
# =============================================================================
# AWS S3 Configuration
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1

# =============================================================================
# OPTIONAL: MONITORING & ANALYTICS
# =============================================================================
# Sentry (error tracking)
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Google Analytics
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
